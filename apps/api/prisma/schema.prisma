generator client {
   provider = "prisma-client-js"
}

datasource db {
   provider = "postgresql"
   url      = env("DATABASE_URL")
}

enum UserRole {
   USER
   ADMIN
   COACH
}

enum MuscleGroup {
   CHEST
   BACK
   LEGS
   SHOULDERS
   ARMS
   CORE
   FULL_BODY
   GLUTES
   CALVES
   CARDIO
}

enum ExerciseCategory {
   STRENGTH
   BODYWEIGHT
   CARDIO
}

enum PersonalRecordMetric {
   ESTIMATED_1RM // mejor 1RM estimado para un ejercicio
   MAX_WEIGHT // mayor peso movido en una serie de un ejercicio
   MAX_REPS // mayor número de reps en una serie de un ejercicio
   MAX_DISTANCE // mayor distancia en una serie de un ejercicio
   MAX_DURATION // mayor duración en una serie de un ejercicio
   EXERCISE_VOLUME // mayor volumen total de un ejercicio dentro de una sesión
   SESSION_VOLUME // mayor volumen total de toda la sesión
}

model User {
   id           String    @id @default(cuid())
   email        String    @unique
   username     String?   @unique
   passwordHash String
   hashedRefreshToken String?
   firstName    String?
   lastName     String?
   role         UserRole  @default(USER)
   weightKg     Float?
   heightCm     Float?
   birthDate    DateTime?
   emailVerifiedAt DateTime?
   emailVerificationTokenHash String?
   emailVerificationExpiresAt DateTime?
   createdAt    DateTime  @default(now())
   updatedAt    DateTime  @updatedAt

   workoutPlans    WorkoutPlan[]
   workoutSessions WorkoutSession[]
   personalRecords PersonalRecord[]
}

model Exercise {
   id           String      @id @default(cuid())
   name         String      @unique
   slug         String      @unique
   description  String?
   instructions String?
   muscleGroup  MuscleGroup
   category     ExerciseCategory @default(STRENGTH)
   equipment    String?
   isCompound   Boolean     @default(false)
   createdAt    DateTime    @default(now())
   updatedAt    DateTime    @updatedAt

   workoutPlanItems WorkoutPlanExercise[]
   workoutSets      WorkoutSet[]
   personalRecords  PersonalRecord[]
}

model WorkoutPlan {
   id          String   @id @default(cuid())
   userId      String
   name        String
   description String?
   isActive    Boolean  @default(true)
   createdAt   DateTime @default(now())
   updatedAt   DateTime @updatedAt

   user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
   exercises WorkoutPlanExercise[]
   sessions  WorkoutSession[]
}

model WorkoutPlanExercise {
   id             String  @id @default(cuid())
   workoutPlanId  String
   exerciseId     String
   order          Int
   targetSets     Int?
   targetRepsMin  Int?
   targetRepsMax  Int?
   targetWeightKg Float?
   restSeconds    Int?
   notes          String?

   workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
   exercise    Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

   @@unique([workoutPlanId, order])
}

model WorkoutSession {
   id            String    @id @default(cuid())
   userId        String
   workoutPlanId String?
   name          String
   notes         String?
   startedAt     DateTime
   endedAt       DateTime?
   createdAt     DateTime  @default(now())

   user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
   workoutPlan WorkoutPlan? @relation(fields: [workoutPlanId], references: [id], onDelete: SetNull)
   sets        WorkoutSet[]
}

model WorkoutSet {
   id               String   @id @default(cuid())
   workoutSessionId String
   exerciseId       String
   setNumber        Int
   reps             Int?
   weightKg         Float?
   durationSeconds  Int?
   distanceMeters   Float?
   rir              Int?
   isWarmup         Boolean  @default(false)
   isCompleted      Boolean  @default(true)
   createdAt        DateTime @default(now())

   workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
   exercise       Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

   @@unique([workoutSessionId, exerciseId, setNumber])
}

model PersonalRecord {
   id         String               @id @default(cuid())
   userId     String
   exerciseId String
   metric     PersonalRecordMetric
   value      Float
   achievedAt DateTime
   createdAt  DateTime             @default(now())

   user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
   exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
}
